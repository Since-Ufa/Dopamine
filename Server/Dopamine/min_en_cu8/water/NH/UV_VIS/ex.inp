# opt in PBE-D3/def2tzvp

! M062X TightSCF def2-TZVP slowconv PModel cpcm(water) 

%tddft
 nroots 12
 maxdim 60
 triplets false
end

%output
Print[ P_Basis ] 2
Print[ P_MOs ] 1
end

%pal nprocs=16 end
%base "neutral"
*xyz 0 2

*



